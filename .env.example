# Environment
ENV=dev

# Database Configuration
# Choose ONE approach based on your deployment:

# APPROACH 1: Development (Docker Compose with individual variables)
# Use this for local development
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=suremind
POSTGRES_USER=postgres
POSTGRES_PASSWORD=super-secret-change-me

# APPROACH 2: Production (Full DATABASE_URL from managed services)
# Use this for Railway, Render, Supabase, etc.
# Uncomment and set when deploying to production:
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Examples by provider:
# Railway: postgresql://postgres:password@containers-us-west-xxx.railway.app:5432/railway?sslmode=require
# Render: postgresql://user:password@dpg-xxx-a.oregon-postgres.render.com:5432/dbname?sslmode=require
# Supabase: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres?sslmode=require

# Redis
REDIS_URL=redis://redis:6379/0

# JWT Security
JWT_SECRET=change_me_in_prod_use_32_plus_random_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - comma separated origins for Next.js
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Cookie Security
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Brevo (Sendinblue) Email Service
BREVO_API_KEY=your-brevo-api-key-here
BREVO_SENDER_EMAIL=noreply@yourapp.com
BREVO_SENDER_NAME=Suremind

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Token Expiration
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_MINUTES=15

# Soft Delete
SOFT_DELETE_DAYS=30
